# Deterministic FATAL-item checks (stage 3). Never use a model.
# Each is a GENERAL PRINCIPLE; project-specific strings come from project.<name>.json
# via {{placeholders}} (expanded by facts.py). To port: change the facts, not these rules.
# fields: name | tool (regex) | inspect (path|content|command|any) | match | unless? | level | message
# level: "reject" = machine-certain violation -> bounce back silently
#        "escalate" = only-human-can-verify the actual code -> stop and ask the user
#
# --- reject (machine-certain, silent bounce) ---
{"name": "train-read-on-fast-storage", "tool": "Bash", "inspect": "command", "level": "reject", "match": "({{launch_re}})[\\s\\S]*({{bad_storage_re}})|--(data|codes|manifest)[_-]?(root|dir|path)[ =]\\S*({{bad_storage_re}})", "message": "Training/data path is on unreliable storage ({{bad_storage}}) — concurrent reads corrupt mid-stream -> backward crashes. Switch to {{good_storage}} and relaunch. (Read-only browsing of jfs is fine; this only fires on a training launch.)"}
{"name": "no-edit-locked-config", "tool": "Edit|Write", "inspect": "path", "level": "reject", "match": "{{locked_configs_re}}", "message": "This is a LOCKED base/infra config. Don't edit it directly — silent overrides are exactly where the scheduler-override / power-mel class of bugs come from. Back out: use an explicit CLI flag or a separate override file, and state why."}
#
# --- escalate (only a human reading the actual code can confirm) ---
{"name": "forward-change-needs-human", "tool": "Edit|Write|MultiEdit", "inspect": "content", "level": "escalate", "verifier": "check_model_code.forward", "machine_certain": false, "message": "This edit touches forward / mask / sampling / generate logic — have the user review the diff ({{forward_example}})."}
{"name": "preproc-matches-frozen-config", "tool": "Edit|Write|MultiEdit", "inspect": "content", "level": "escalate", "verifier": "check_mel_power.mel_power", "message": "You changed the mel preprocessing fed to {{frozen_component}}, but it isn't aligned with its training config — don't trust library defaults ({{preproc_example}}). Please have the user confirm."}
{"name": "codec-encode-params-match", "tool": "Edit|Write|MultiEdit", "inspect": "content", "level": "escalate", "verifier": "check_frozen_encode.check", "message": "Codec encode params do not match the frozen component's declared contract."}
{"name": "ar-shift-present", "tool": "Edit|Write|MultiEdit", "inspect": "content", "level": "escalate", "verifier": "check_model_code.loss", "machine_certain": false, "message": "Edited a loss function but the AR off-by-one slice is missing — confirm the shift is there."}
{"name": "padding-encodes-OOD", "tool": "Edit|Write|MultiEdit", "inspect": "content", "level": "escalate", "match": "{{pad_ood_re}}", "message": "Using np.zeros to fill audio silence/gaps — a frozen tokenizer has never seen pure zeros and encodes them to OOD codes ({{pad_ood_example}}). Please have the user confirm."}
{"name": "silent-truncation", "tool": "Edit|Write|MultiEdit", "inspect": "content", "level": "escalate", "match": "keep\\s*=\\s*min\\(|\\[\\s*[\\w]+\\s*-\\s*keep\\s*:\\s*\\]|\\[-\\s*keep\\s*:\\]", "message": "Saw a right-aligned truncation (keep only the last `keep` tokens) — long sequences lose the HEAD (here, 250 tokens kept only 79, dropping the whole question context). Please have the user confirm the truncation direction + whether the truncation rate should be logged."}
