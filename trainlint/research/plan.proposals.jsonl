# Project PLAN: proposals — turn trainlint's single mutable plan into a managed, append-only
# collection of PROPOSALS (each = a frozen plan snapshot / one research bet), with a viz
# management surface. Each line is one DECISION tagged with its governing PRINCIPLE.
# fields: id | phase | decision | choice | principle | why | status(open|decided|verified) | match(regex)
{"id": "proposal-snapshot", "phase": "what a proposal is", "decision": "What is a 'proposal' as a unit of storage?", "choice": "An immutable, frozen snapshot of a WHOLE plan (the full ordered decision list) at one moment — one research bet. The working plan is edited; snapshotting it mints a proposal that is then written-once.", "principle": "append-only-record", "why": "Today a plan is a mutable singleton — plan.py:49 load() reads one plan.<name>.jsonl and each /plan run overwrites/extends it, so every prior state is lost. Making each bet a durable artifact is the whole feature.", "status": "decided", "match": "proposal|snapshot|plan\\.[\\w-]+\\.jsonl", "pillar": true}
{"id": "flat-collection", "phase": "what a proposal is", "decision": "Is there a single 'active' plan, or many coexisting proposals?", "choice": "A FLAT, independent collection — many proposals coexist in a repo with NO privileged 'active' one. Proposals (like today's projects) have no relationship to each other.", "principle": "flat-independent-collection", "why": "trainlint forces one-at-a-time today: plan.py:34-46 _active() reads a single .active-project string and new_project.py:67 overwrites it. The user wants N coexisting bets with no active/inactive distinction at all.", "status": "decided", "match": "\\.active-project|_active\\(|active.?project|HARNESS_PROJECT", "pillar": true, "not_this": "keeping .active-project as the privileged 'current' plan that exactly one proposal must occupy", "not_re": "(set|switch|overwrite|write).{0,24}\\.?active.?project"}
{"id": "no-rollback", "phase": "what a proposal is", "decision": "What happens to a failed or abandoned bet?", "choice": "Never deleted, never rolled back. It stays as a recorded proposal with a terminal status + an outcome note ('tried X, failed because Y'). The record IS the value.", "principle": "append-only-record", "why": "trainlint exists to keep institutional memory of what was tried and why it failed; rolling back a bet would erase exactly that memory. Append-only is non-negotiable per the user.", "status": "decided", "match": "rollback|roll.?back|revert|delete.{0,12}proposal|abandon|discard"}
{"id": "proposal-keying", "phase": "what a proposal is", "decision": "How are proposals keyed and laid out on disk so many can coexist?", "choice": "", "principle": "proposal-addressing", "why": "Files today are keyed only by project name (plan.<name>.jsonl, plan.py:51). For N coexisting proposals we need a proposal id + a registry/index — open whether that's a directory per repo, an id suffix on the filename, or a single manifest file.", "status": "open", "match": "proposals?/|registry|manifest|index\\.jsonl|p\\d{3}"}
{"id": "proposal-status", "phase": "status & history", "decision": "What lifecycle states does a proposal carry, and at what altitude?", "choice": "A NEW plan-level status field (e.g. draft / active / accepted / superseded / abandoned), DISTINCT from the existing per-decision status (open|decided|verified at plan.py:31).", "principle": "status-at-the-right-altitude", "why": "Today the only statuses live on individual decisions (plan.py:31). A proposal needs its own lifecycle independent of whether its component decisions happen to be decided.", "status": "decided", "match": "draft|accepted|superseded|abandoned|proposal.?status|lifecycle", "pillar": true}
{"id": "snapshot-trigger", "phase": "status & history", "decision": "When is a new proposal snapshot minted?", "choice": "Each /plan run that materially changes the plan mints a new proposal snapshot — 每次plan都是一个proposal.", "principle": "plan-run-is-a-proposal", "why": "The user's Q1 answer: each plan run = a proposal. Keeps the mapping simple and makes every planning act a durable, comparable artifact instead of an in-place overwrite.", "status": "decided", "match": "snapshot|mint|/plan|trainlint:plan|commit.{0,10}plan"}
{"id": "lineage-link", "phase": "status & history", "decision": "How do proposals link across versions (the lineage of bets)?", "choice": "", "principle": "lineage-pointer", "why": "Append-only history is only navigable if a proposal records what it supersedes; open whether that's a parent/supersedes id pointer, a named branch, or plain timestamp order.", "status": "open", "match": "supersede|parent|lineage|branch|ancestor|derive"}
{"id": "viz-index", "phase": "the report UI", "decision": "How does viz become the management surface for many proposals?", "choice": "", "principle": "overview-first", "why": "viz today renders exactly one project (viz.py:889 generate(name)) with no index. 'Manageable' = an overview that lists every proposal with status + filter BEFORE drilling into one.", "status": "open", "match": "viz|index|dashboard|list.{0,10}proposal|overview", "pillar": true}
{"id": "viz-compare", "phase": "the report UI", "decision": "How do you compare two proposals?", "choice": "", "principle": "diff-not-dump", "why": "History+compare (the user's Q2) needs a decision-level diff — which decisions were added, changed, dropped, restatused — between any two proposals. viz has no diff today.", "status": "open", "match": "diff|compare|versus|side.?by.?side"}
{"id": "hooks-target", "phase": "wiring it in", "decision": "Without a single active project, what do the online doorman/compass enforce against?", "choice": "", "principle": "enforcement-needs-a-target", "why": "The online layer assumes ONE active plan: plan.py _active() and the SessionStart/compass/doorman (router.py, planaware.py, surfacer.py) all key off .active-project. Drop the active singleton and they have no target. This is the cheapest test that could invalidate the flat-collection model — if enforcement can't be retargeted, the architecture needs a rethink.", "status": "open", "load_bearing": true, "match": "doorman|compass|router\\.py|planaware|surfacer|SessionStart|_active"}
{"id": "migrate-existing", "phase": "wiring it in", "decision": "How do today's single-plan projects (megafish/asr/kimi) become proposals?", "choice": "", "principle": "backward-compatible-migration", "why": "Existing plan.<name>.jsonl files must keep working; cleanest is to treat each as the first proposal (p001) of its repo, with reads degrading gracefully (plan.py:54 already returns [] when a file is absent).", "status": "open", "match": "migrat|backward|compat|legacy|plan\\.[\\w-]+\\.jsonl"}
