# Project PLAN for mimo (duplex MiMo) — the ordered DECISIONS that define the run, each
# tagged with the transferable PRINCIPLE that governs it. Worked example; this is the
# "floor plan" the plan-quiz teaches from and the plan-aware doorman locates actions on.
# fields: id | phase | decision | choice | principle | why | status(open|decided|verified) | match(regex)
# principle ids link to quiz.jsonl (reuse one if it fits; coin a kebab id if not).
{"id": "data-storage", "phase": "data", "decision": "Which storage do training workers read data from?", "choice": "minio (full-flash); never jfs", "principle": "verify-data-before-blaming-algorithm", "why": "jfs corrupts under concurrent reads -> garbage wav -> NaN -> backward illegal-mem that looks like a model bug", "status": "verified", "match": "/jfs/|/mnt/jfs|minio|data.?root|data.?dir|storage"}
{"id": "dedup-split", "phase": "data", "decision": "How do we split train/val without leakage?", "choice": "dedup on the full (session, window) key, not session_id alone", "principle": "dedup-on-the-full-identity-key", "why": "one session is cut into many windows; dedup by session_id alone scatters its windows across train and val -> inflated eval", "status": "verified", "match": "dedup|train.?val|\\bsplit\\b|session.?id|leak"}
{"id": "silence-padding", "phase": "preproc", "decision": "How do we fill the silent gaps between turns when synthesizing dialogue?", "choice": "NOT np.zeros — real recordings have floor noise; zeros are OOD", "principle": "frozen-component-contract", "why": "the frozen tokenizer never saw pure zeros -> maps them to a fixed garbage code (351), which became ~40% of training targets", "status": "verified", "match": "np\\.zeros|silence|\\bpad\\b|gap|fill"}
{"id": "mel-power", "phase": "preproc", "decision": "What MelSpectrogram config do we feed the frozen codec?", "choice": "power=1.0 (magnitude) — match the codec's training config bit-for-bit", "principle": "frozen-component-contract", "why": "codec was frozen at power=1.0; torchaudio's default power=2.0 (energy) -> squared -> OOD codes, ~72% differ", "status": "verified", "match": "MelSpectrogram|mel_spectrogram|\\bmel\\b|\\bpower\\b|\\bencode\\b"}
{"id": "ckpt-init", "phase": "ckpt", "decision": "What do we bootstrap each new duplex run from?", "choice": "fresh from base every time; never from a previous duplex ckpt", "principle": "fresh-not-continued-when-the-design-changed", "why": "continuing a prior duplex ckpt carries forward its rot; design/loss/data changes must be re-learned from a clean base", "status": "decided", "match": "ckpt|checkpoint|resume|pretrained|from.?base|init.?from", "not_this": "continuing/resuming a NEW run from a previous duplex checkpoint (instead of fresh-from-base)", "not_re": "(resume|continue|继续|接着).{0,20}dup_|--resume\\b|(resume|continue|继续).{0,14}(from )?(the )?(previous|prior|之前|上一个).{0,12}(duplex|ckpt|checkpoint|检查点|run)|load.{0,12}dup_d3v"}
{"id": "ar-shift", "phase": "model", "decision": "Is the autoregressive off-by-one preserved in the loss after our edits?", "choice": "keep logits[:,:-1] vs labels[:,1:] exactly as base", "principle": "train-infer-parity", "why": "drop the shift and the model predicts token t from token t -> learns to echo its input (one token repeated forever)", "status": "verified", "match": "cross_entropy|F\\.cross_entropy|labels|shift_logits|\\bloss\\b"}
{"id": "stream-layout", "phase": "model", "decision": "How do we lay out the user and assistant streams?", "choice": "stream/interleave; NOT parallel chunk", "principle": "a-gate-copied-across-regimes-misfires", "why": "parallel chunk breaks base's mutual-exclusion premise; the copied is_speech gate then zeros the assistant's own audio feedback", "status": "verified", "match": "layout|chunk|interleave|is_speech|mutual.?excl"}
{"id": "role-emb", "phase": "model", "decision": "How does the model tell the user audio stream from the assistant's?", "choice": "needs comparable magnitude or separate params — not a tiny additive role constant", "principle": "small-additive-signal-gets-swamped", "why": "the role constant trained to ~1e-5 while the code-embedding norm is ~0.6 -> swamped -> the streams cross-talk", "status": "decided", "match": "role|speaker|user.?asst|role.?emb|additive"}
{"id": "empty-loss-weight", "phase": "loss", "decision": "What loss weight do we put on the majority 'empty/quiet' target?", "choice": "raise it; the inherited 0.01 under-trains 'stay quiet'", "principle": "majority-class-loss-weight-sets-behavior", "why": "~95% of duplex positions target empty; weight 0.01 -> model never learns to abstain -> talks non-stop. NOT a temperature problem", "status": "decided", "match": "empty_loss|loss.?weight|speech.?weight|empty.?weight|abstain"}
{"id": "eff-batch", "phase": "train", "decision": "How do we reach effective batch >=512 without OOM?", "choice": "grad-accum, not per_device stacking", "principle": "backward-is-the-memory-bottleneck", "why": "backward peak (grads+activations) scales linearly with per_device -> illegal-mem; grad-accum sums gradients without raising the peak", "status": "verified", "match": "per_device|grad.?accum|eff.?batch|batch.?size|global.?batch"}
{"id": "lr-regime", "phase": "train", "decision": "What LR for full-FT no-freeze?", "choice": "re-scale, don't copy base's LoRA 2e-5; full-FT uses ~5e-6 cosine", "principle": "hparams-dont-transfer-across-regimes", "why": "LoRA updates few params so 2e-5 fits; full-FT updates all params and the same LR steps too big -> overfit/diverge", "status": "decided", "match": "\\blr\\b|learning_rate|lora|full.?ft|nofreeze|freeze"}
{"id": "scheduler-source", "phase": "train", "decision": "Who actually owns the LR schedule?", "choice": "print the EFFECTIVE schedule; DeepSpeed's ds_config silently overrides the sbatch flag", "principle": "config-from-many-sources-silently-overrides", "why": "when DeepSpeed owns scheduling its config block wins; you write cosine, it runs linear, nothing warns you", "status": "verified", "match": "scheduler|deepspeed|ds_config|cosine|linear|lr_scheduler"}
{"id": "train-enough", "phase": "train", "decision": "Have we trained long enough before judging a result?", "choice": "rule out under-training (>=3 epochs) before blaming the design", "principle": "rule-out-the-trunk-before-blaming-a-branch", "why": "robotic audio looked like a loss-weights bug; the real cause was 1.26 epochs + the power bug — a trunk fault, not the branch", "status": "decided", "match": "epoch|under.?train|trained.?enough|steps"}
{"id": "eval-protocol", "phase": "eval", "decision": "How do we measure whether the model actually learned to generate audio?", "choice": "free-running generation -> ASR -> CER; NOT teacher-forced top-1", "principle": "free-running-not-teacher-forced-is-the-test", "why": "TF feeds the GT past so continuing one frame is easy; free-running compounds errors and exposes collapse. TF is local, generation is global", "status": "verified", "match": "teacher.?forc|tf_top1|top.?1|free.?run|自由生成|\\bcer\\b|\\beval\\b|\\bgenerate\\b"}
{"id": "eval-metric", "phase": "eval", "decision": "How do we read an aggregate accuracy number?", "choice": "split silence vs speech region; don't trust the aggregate", "principle": "beware-the-trivially-predictable-majority", "why": "~70% of frames are silence (trivially predicted by copying the previous frame); 62% aggregate is almost all 'got silence right', real speech is 12%", "status": "verified", "match": "accuracy|top.?1|aggregate|\\bmetric\\b|准确率|ablation"}
{"id": "eval-crutch", "phase": "eval", "decision": "Does the eval hand the model help that deployment won't have?", "choice": "no onset_floor / forced-text crutch in turn-taking eval", "principle": "eval-conditions-must-equal-deployment", "why": "onset_floor secretly gives the model the GT user-end (the hardest sub-task); deployment has none -> autonomous onset breaks", "status": "decided", "match": "onset.?floor|forced.?text|crutch|强制|turn.?tak"}
{"id": "streaming-encoder", "phase": "deploy", "decision": "Can we use base's bidirectional encoder for streaming deployment?", "choice": "OPEN — bidir leaks the future; offline looks perfect, streaming is OOD", "principle": "info-set-must-match-deployment-causality", "why": "a bidirectional encoder attends the whole segment, so 'now' already encodes the future; streaming has only up-to-now -> codes go OOD", "status": "open", "load_bearing": true, "match": "encoder|bidirectional|streaming|流式|causal"}
