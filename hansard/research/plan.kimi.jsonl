# Project PLAN for the "kimi" project — porting hansard to the Kimi CLI (Kimi Code).
# Each DECISION is grounded in the Kimi source read at
# ~/.local/share/uv/tools/kimi-cli/lib/python3.13/site-packages/kimi_cli (v1.48.0).
# fields: id | phase | decision | choice | principle | why | status(open|decided|verified) | match(regex)
# load_bearing = the one open decision that gates the rest; pillar = a core dimension always in view.
{"id": "kimi-hook-config", "phase": "protocol", "decision": "How are hansard's hooks registered in Kimi?", "choice": "config.toml flat list: each entry {event, command, matcher, timeout} (HookDef) — NOT Claude/Codex nested hooks.json", "principle": "read-the-host-contract", "why": "kimi_cli/hooks/config.py:23-42 — HookDef has ONE event per entry; app.py:325 builds HookEngine(config.hooks); so one Claude event-group becomes N flat entries", "status": "verified", "pillar": true, "match": "config\\.toml|HookDef|hooks\\s*="}
{"id": "kimi-events", "phase": "protocol", "decision": "Which lifecycle events exist, and which do we wire?", "choice": "wire SessionStart, UserPromptSubmit, PreToolUse, PreCompact, SessionEnd, Stop — all present in Kimi", "principle": "read-the-host-contract", "why": "config.py HookEventType lists 13 events incl. SessionEnd (events.py:106) — so harvest gets a real SessionEnd here, unlike Codex which lacked it", "status": "verified", "pillar": true, "match": "SessionStart|UserPromptSubmit|PreToolUse|PreCompact|SessionEnd|\\bStop\\b"}
{"id": "kimi-tool-names", "phase": "protocol", "decision": "What tool names does PreToolUse match against?", "choice": "matcher hits tool_name; mutating tools are Shell | WriteFile | StrReplaceFile", "principle": "tool-name-mapping", "why": "shell/__init__.py:61 Shell, write.py:41 WriteFile, replace.py:44 StrReplaceFile; toolset.py:387 passes matcher_value=tool_name", "status": "verified", "match": "Shell|WriteFile|StrReplaceFile|tool_name"}
{"id": "kimi-output-model", "phase": "channels", "decision": "Kimi hooks are block-only (no additionalContext/systemMessage injection). How do we deliver the soft channels — compass, coach, escalate?", "choice": "Gate + escalate-by-block: reject works natively; escalate is converted to a permissionDecision:deny carrying the alert as the reason (rare, destructive — drops the action/prompt to force a look); coach is DROPPED (no native path)", "principle": "host-channel-fit", "why": "runner.py:77-82 parses ONLY hookSpecificOutput.permissionDecision==deny; kimisoul.py:618/665 and toolset.py:397 read ONLY result.action+reason; HookResult.stdout is never injected. adapt_for_kimi() in kimi_compat folds escalate->deny and drops coach", "status": "decided", "load_bearing": true, "pillar": true, "not_this": "assuming additionalContext/systemMessage reach the agent on Kimi the way they do on Claude/Codex", "not_re": "additionalContext|systemMessage"}
{"id": "kimi-reject-channel", "phase": "channels", "decision": "How does the safety REJECT channel work?", "choice": "PreToolUse block via permissionDecision:deny -> tool denied, reason returned to the agent as a ToolError", "principle": "fail-open-never-exit-block", "why": "toolset.py:397-405 — on action==block returns ToolError(message=reason); the mel-power/frozen-encode/manifest-leak verifiers port unchanged as deny", "status": "verified", "match": "permissionDecision|deny|reject|PreToolUse"}
{"id": "kimi-report-doorman", "phase": "channels", "decision": "Does the plan-report doorman (Stop rewrite) port?", "choice": "yes — Stop block+reason re-runs the turn with reason as a user message", "principle": "report-as-gate", "why": "kimisoul.py:656-670 — on Stop, action==block and reason -> _turn(reason) once (stop_hook_active guard); identical to reportcheck.py's decision:block rewrite", "status": "verified", "match": "Stop|reportcheck|stop_hook_active|rewrite"}
{"id": "kimi-harvest", "phase": "channels", "decision": "Where does harvest (knowledge capture before context loss) run?", "choice": "PreCompact + SessionEnd as side-effect hooks (output ignored)", "principle": "anchor-to-work-not-session", "why": "kimisoul.py:1307 fires PreCompact; SessionEnd exists (events.py:106). Both are fire-and-forget for output, but the side effect (harvest.py writing knowledge) runs — and Kimi HAS SessionEnd, so this matches Claude better than the Codex port", "status": "decided", "match": "PreCompact|SessionEnd|harvest"}
{"id": "kimi-exit-safety", "phase": "channels", "decision": "Can a harness bug lock the Kimi session (the lockout footgun)?", "choice": "no — router always exits 0 and blocks only via permissionDecision; a missing script exits 127 (not 2) -> allow", "principle": "fail-open-never-exit-block", "why": "runner.py:71 blocks on exit_code==2; hansard never exits 2; runner wraps subprocess in try->allow and treats timeout as allow (runner.py:46), so fail-open holds", "status": "verified", "match": "exit\\s*2|exit_code|fail.?open|lockout"}
{"id": "kimi-tool-shim", "phase": "shim", "decision": "How does the pipeline read Kimi's edit/write/shell tool_input?", "choice": "kimi_compat.normalize maps Shell->Bash(command), WriteFile->Write(path->file_path), StrReplaceFile->Edit(path->file_path, edit{old,new}->edits/new_string)", "principle": "tool-name-mapping", "why": "write.py Params{path,content,mode}; replace.py Params{path, edit: Edit|list[Edit]} with Edit{old,new,replace_all}; shell Params{command} — field names differ from Claude's file_path/new_string, so normalize before prefilter/checks (mirrors codex_compat.py)", "status": "decided", "match": "kimi_compat|StrReplaceFile|WriteFile|tool_input"}
{"id": "kimi-install", "phase": "packaging", "decision": "How is hansard installed into Kimi?", "choice": "install-kimi.sh merges [[hooks]] entries into ~/.kimi/config.toml, idempotent, absolute paths baked", "principle": "bake-paths-dont-trust-env", "why": "Kimi has no ${CLAUDE_PLUGIN_ROOT}; config.hooks is read from ~/.kimi/config.toml (app.py:325). Merge (not overwrite) to preserve the user's existing hooks/config", "status": "decided", "match": "install-kimi|config\\.toml|\\[\\[hooks\\]\\]"}
{"id": "kimi-commands", "phase": "packaging", "decision": "How do the 5 slash commands port?", "choice": "as Kimi skills via extra_skill_dirs; each <dir>/hansard-<name>/SKILL.md, invoked /skill:hansard-<name>", "principle": "host-channel-fit", "why": "skill/__init__.py:189,436 — extra_skill_dirs is additive; canonical layout <skills_dir>/<name>/SKILL.md with name/description frontmatter; slash.py:54 exposes them under the skill: prefix", "status": "decided", "match": "skill|extra_skill_dirs|SKILL\\.md|slash"}
