{
  "_comment": "Codex port of hooks/hooks.json. Codex cloned Claude Code's hook schema (same hookSpecificOutput fields, same ${CLAUDE_PLUGIN_ROOT} alias), so the only deltas are: PreToolUse matcher Bash|apply_patch (no Edit/Write/Read in Codex), and harvest on PreCompact (Codex has no SessionEnd). install-codex.sh bakes the absolute hansard root into this before merging it into ~/.codex/hooks.json.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/research/flow.py\"" }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/router.py\"" },
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/research/flow.py\"" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch",
        "hooks": [
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/router.py\"" }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/research/harvest.py\"" }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "python3 \"${CLAUDE_PLUGIN_ROOT}/hooks/router.py\"" }
        ]
      }
    ]
  }
}
