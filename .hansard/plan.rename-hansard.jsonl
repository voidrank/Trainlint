# plan.rename-hansard.jsonl — one decision per line; see plan.py for the renderer
{"id": "rename-boundary", "phase": "scope", "decision": "Which name-surfaces get renamed vs permanently grandfathered? Visible-to-humans (commands, portal titles, repo, docs, env vars w/ fallback) vs state-carrying invisibles (R2 bucket, cookie name, localStorage keys, data dirname, worker name).", "choice": "Rename ONLY human-visible surfaces: /hansard:* commands (plugin id + repo), portal/README brand, HANSARD_* env with TRAINLINT_* fallback. Permanently grandfather every state-carrying invisible: R2 bucket trainlint-reports, cookie trainlint_token, localStorage trainlint_ann_*, data dirname trainlint-trainlint, worker name trainlint-report-server.", "status": "decided", "level": "high", "pillar": true, "load_bearing": false, "principle": "rename-visible-grandfather-state", "why": "Renaming a state-carrying id (cookie in every user's browser, localStorage annotations, R2 object keys) has real breakage and zero visible payoff; renaming visible ids is the whole point. The boundary decides every other decision's scope.", "match": "trainlint.*hansard|hansard.*rename|grandfather", "plain": "Decide which of the six layers actually change name, and which keep the old name forever on purpose."}
{"id": "brand-strings", "phase": "brand", "decision": "Swap the display-only strings: portal titles (Trainlint Portal / trainlint reports / trainlint · admin), plugin.json description, README headers.", "choice": "Rename display strings to Hansard; zero path/id changes; ship as a normal version bump. VERIFIED 2026-07-08: live probes show <title>Login - hansard</title>, <h2>Hansard</h2>, tagline 'The work, on the record', admin/index titles hansard — deployed version 572f6ae1 at 100%.", "status": "verified", "level": "impl", "principle": "cheap-visible-first", "why": "Pure string swaps in index.js loginPage/admin/index titles + README — cannot break anything; delivers the visible rename immediately.", "match": "Trainlint Portal|trainlint reports|trainlint · admin", "plain": "Change what the product calls itself on screen — nothing structural.", "artifact": "report-server/worker/src/index.js"}
{"id": "plugin-id-migration", "phase": "identity", "decision": "How to flip the plugin identity: repo voidrank/Trainlint rename, marketplace.json + plugin.json name → hansard, reinstall (hansard@hansard), settings.json hooks rewrite, /hansard:* prefix.", "choice": "Mechanics settled: gh repo rename Trainlint→Hansard (GitHub auto-redirects the marketplace clone), plugin.json+marketplace.json name→hansard, operator reinstalls (hansard@hansard), settings.json hooks keys rewritten; executed only at the coordinated cut.", "status": "decided", "level": "high", "pillar": true, "principle": "identity-flip-is-reinstall", "why": "The plugin name derives the command prefix, cache path and install key (installed_plugins.json: trainlint@trainlint) — so this is an uninstall/reinstall event that must be coordinated, not a string swap. GitHub auto-redirects the renamed repo so the marketplace clone keeps pulling.", "match": "plugin\\.json|marketplace\\.json|installed_plugins|/hansard:", "plain": "Changing the plugin's registered name means reinstalling it under the new identity — plan it like a migration, not an edit."}
{"id": "env-compat", "phase": "env", "decision": "How the 21 TRAINLINT_* env vars become HANSARD_* without breaking existing shells/cron.", "choice": "One env helper: read HANSARD_X, fall back to TRAINLINT_X; docs advertise only HANSARD_*; old names never removed.", "status": "decided", "level": "impl", "principle": "dual-read-transition", "why": "21 distinct vars are set in operators' shells and cron — a hard cutover silently disables features (e.g. TRAINLINT_REPORT_TOKEN=none opt-outs).", "match": "TRAINLINT_[A-Z_]+|HANSARD_[A-Z_]+", "not_this": "a blind global sed TRAINLINT_→HANSARD_ with no fallback path", "not_re": "sed[^\\n]*TRAINLINT_[^\\n]*HANSARD_", "plain": "New env names work everywhere, old ones keep working forever via fallback."}
{"id": "data-root-migration", "phase": "data", "decision": "Does data_root move from data/trainlint-trainlint to a hansard path, and if so how (stop daemons → mv → patch paths.py:33 + keepalive.sh + crontab → restart)?", "choice": "No move — dirname grandfathered. Only alias: HANSARD_DATA_DIR honored via the env-compat shim; paths.py literal stays.", "status": "decided", "level": "high", "principle": "identity-in-content-not-path", "why": "The dir holds all project substrate + .token (identity = sha256 of file CONTENT, so a move preserves the paired ns) — but two live daemons + a every-minute cron write into it, so a move is a choreographed restart, and grandfathering the dirname is a legitimate zero-risk alternative.", "match": "data_root|trainlint-trainlint|keepalive|crontab", "plain": "Decide whether the invisible data directory is worth moving at all — and if yes, script the move so the running daemons never write into a vanished path."}
{"id": "state-continuity", "phase": "cloud", "decision": "Strategy for the four cloud state-carriers: worker name (trainlint-report-server), R2 bucket (trainlint-reports — R2 buckets cannot be renamed), cookie trainlint_token (in every user's browser), localStorage trainlint_ann_<project> (viewers' annotations).", "choice": "All four grandfathered forever (per rename-boundary): no dual-read needed, zero code change — the names stay, users keep sessions and annotations. VERIFIED 2026-07-09 on the local worker deployment: old trainlint_token cookie → 200 (dual-read), upload/view/relay all green; suffix checks widened for both eras (b66946e).", "status": "verified", "level": "high", "pillar": true, "principle": "state-outlives-brands", "why": "Cookie rename = every user logged out; localStorage rename = every viewer's annotations gone; R2 rename = full object copy. Each needs grandfather or dual-read — none can be a blind swap.", "match": "trainlint_token|trainlint_ann_|trainlint-reports|trainlint-report-server", "plain": "The name is baked into things users' browsers and the storage bucket already hold — choose per-item: keep the old name, or read both during a transition."}
{"id": "concurrent-session-handoff", "phase": "identity", "decision": "How the rename lands without breaking the other actively-developing session (0.3.56 and climbing, daemons from 0.3.50/0.3.53 running).", "choice": "", "status": "open", "level": "high", "principle": "never-pull-the-rug", "why": "That session ships multiple versions/day onto the same master and its daemons run from versioned cache paths; a repo/plugin rename mid-burst orphans its checkout and its keepalive. The rename must land as a coordinated cut it opts into.", "match": "0\\.3\\.5[0-9]|keepalive|relay_agent|chat_backend", "plain": "Sequence the flip so the other Claude session finishes or pauses first — the rename is a stop-the-world moment for developers, not for users.", "load_bearing": true}
